# ─────────────────────────────────────────────
# Portail SESAM-Vitale
# ─────────────────────────────────────────────
SESAM_URL=https://portail-support.sesam-vitale.fr/gsvextranet/#/all-requests
SESAM_USERNAME=votre_identifiant
SESAM_PASSWORD=votre_mot_de_passe

# Mettre à true pour lancer le navigateur en mode visible (debug)
SESAM_HEADLESS=true

# ─────────────────────────────────────────────
# Stockage local de l'état (pour détecter les nouveautés)
# ─────────────────────────────────────────────
STATE_FILE=.sesam_state.json
